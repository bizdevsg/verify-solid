# Production backend environment.
#
# Copy to backend/.env and fill in every CHANGE_ME value:
#   cp backend/.env.production.example backend/.env
#
# The DB_*, LIVEKIT_*, and DOMAIN-derived values here must match what you put
# in the repo-root .env (copied from .env.production.example) — docker-compose
# passes DB_HOST/REDIS_HOST/LIVEKIT_HOST/LIVEKIT_URL itself, but everything
# else below is read from this file via env_file.

APP_NAME="Solid Video Verification"
APP_ENV=production
# Generate once with: php artisan key:generate --show (run inside the
# container after first build), then paste the base64:... value here.
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://yourdomain.com

FRONTEND_URL=https://yourdomain.com
SANCTUM_STATEFUL_DOMAINS=yourdomain.com
SESSION_DOMAIN=yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# DB_HOST/DB_DATABASE/DB_USERNAME/DB_PASSWORD are overridden by
# docker-compose.yml's `environment:` block for the backend service (reading
# from the repo-root .env) — the values below are only used if you run the
# backend outside Docker.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=solid_video_verification
DB_USERNAME=solid
DB_PASSWORD=CHANGE_ME_match_root_env

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# LIVEKIT_API_KEY/SECRET/URL are overridden by docker-compose.prod.yml from
# the repo-root .env (single source of truth) — the values below only apply
# if you run the backend outside Docker.
LIVEKIT_API_KEY=CHANGE_ME_match_root_env
LIVEKIT_API_SECRET=CHANGE_ME_match_root_env
LIVEKIT_HOST=http://livekit:7880
LIVEKIT_URL=wss://livekit.yourdomain.com

# MinIO — recording storage. MINIO_ACCESS_KEY/SECRET_KEY are overridden by
# docker-compose.yml from the repo-root .env's MINIO_ROOT_USER/PASSWORD
# (single source of truth); the values below only apply outside Docker.
# Recording adds real CPU/RAM load (LiveKit Egress) — keep an eye on server
# load on small VPS sizes.
MINIO_ACCESS_KEY=CHANGE_ME_match_root_env
MINIO_SECRET_KEY=CHANGE_ME_match_root_env
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=recordings
MINIO_REGION=us-east-1
