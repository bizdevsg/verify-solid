APP_NAME="Solid Video Verification"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost,127.0.0.1:3000,127.0.0.1
SESSION_DOMAIN=localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Use host "db" when running via docker-compose, or 127.0.0.1 for a local MySQL server.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=solid_video_verification
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Agora (video calls). Get App ID + App Certificate from the Agora Console
# project itself; Customer ID/Secret are separate — they're generated under
# Agora Console > RESTful API, and only authenticate Cloud Recording calls.
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=
# Public hostname Agora's Cloud Recording servers upload to — NOT the
# internal `minio:9000` address below, since Agora's servers reach this over
# the real internet, not the docker network. See DEPLOYMENT.md.
AGORA_RECORDING_STORAGE_ENDPOINT=

# MinIO — recording storage (the "recordings" disk in config/filesystems.php).
# MinIO has no host port mapping (same as db/redis), so this only resolves
# when the backend itself runs inside docker-compose too. Running the
# backend standalone via `php artisan serve`? Recording is skipped with a
# logged warning instead of failing the call — everything else still works.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=recordings
MINIO_REGION=us-east-1
