# Production Docker Compose environment.
#
# Copy to .env in the repo root and fill in every CHANGE_ME value:
#   cp .env.production.example .env
#
# This file is consumed by docker-compose.yml + docker-compose.prod.yml, by
# infrastructure/certbot/init-letsencrypt.sh, and by
# infrastructure/nginx/render-prod-conf.sh. Never commit the filled-in .env.

# ---- Domain / TLS -----------------------------------------------------
# DNS A records for BOTH of these must point at this server's public IP
# before running init-letsencrypt.sh:
#   yourdomain.com          -> app + API
#   livekit.yourdomain.com  -> video call signaling (needs its own TLS
#                              endpoint so the browser can use wss://)
DOMAIN=yourdomain.com
CERTBOT_EMAIL=CHANGE_ME_your-email@example.com

# ---- MySQL --------------------------------------------------------------
DB_DATABASE=solid_video_verification
DB_USERNAME=solid
# Generate with: openssl rand -hex 24
DB_PASSWORD=CHANGE_ME_generate_a_strong_password
DB_ROOT_PASSWORD=CHANGE_ME_generate_a_different_strong_password

# ---- LiveKit (self-hosted) ----------------------------------------------
# Generate a real key/secret pair — NEVER reuse the "devkey" values from
# local development. Example: openssl rand -hex 16 (key), openssl rand -hex 32 (secret)
LIVEKIT_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_16
LIVEKIT_API_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ---- Frontend session cookie name ---------------------------------------
# Must match backend/.env's derived cookie name: Str::slug(APP_NAME, '_') . '_session'.
# Leave as-is unless you changed APP_NAME.
SESSION_COOKIE_NAME=solid_video_verification_session
