# Base URL of the Laravel backend (no trailing slash, no /api/v1 suffix).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Must match the backend's derived session cookie name
# (Str::slug(APP_NAME, '_') . '_session'), used only for the lightweight
# route-protection check in src/proxy.ts.
NEXT_PUBLIC_SESSION_COOKIE=solid_video_verification_session
