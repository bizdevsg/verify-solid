# Root Docker Compose environment (local development only — do not use these secrets in production)

APP_NAME="Solid Video Verification"
APP_URL=http://localhost

# MySQL
DB_DATABASE=solid_video_verification
DB_USERNAME=solid
DB_PASSWORD=solid_secret
DB_ROOT_PASSWORD=root_secret

# Redis
REDIS_PASSWORD=

# MinIO (stores call recordings — never MySQL, never a public URL)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
